# AIRFLOW_UID: UID user di host (penting agar folder ./logs tidak permission error)
# Di Linux/Mac jalankan: echo "AIRFLOW_UID=$(id -u)" >> .env
# Di Windows (WSL2): isi dengan 50000
AIRFLOW_UID=50000

# Fernet Key untuk enkripsi koneksi di Airflow
# Generate ulang dengan:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0nIe2lc=

# Airflow DB
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=default
